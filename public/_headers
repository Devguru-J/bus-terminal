# Cloudflare Pages 보안 헤더 — 전 라우트 적용
# CSP의 script-src 'unsafe-inline'는 index.html의 JSON-LD를 허용하기 위함
# (사용자 입력을 HTML로 렌더하지 않고 eval도 사용하지 않으므로 실질적 XSS 표면은 없음)

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://vyjolbszizgrspawcdio.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable
