# Cloudflare Pages 보안 헤더 — 전 라우트 적용
# CSP의 script-src 'unsafe-inline'는 index.html의 JSON-LD와 GTM 부트스트랩을 허용하기 위함
# (사용자 입력을 HTML로 렌더하지 않고 eval도 사용하지 않으므로 실질적 XSS 표면은 없음)

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://lh3.googleusercontent.com https://avatars.githubusercontent.com https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://vyjolbszizgrspawcdio.supabase.co https://cloudflareinsights.com https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://region1.google-analytics.com; frame-src https://www.googletagmanager.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# 해시 번들된 자산은 immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# index.html은 절대 캐시 금지 — 새 배포 시 클라이언트가 옛 hashed chunk를 요청해
# SPA fallback HTML을 받는 MIME 에러를 방지한다.
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
